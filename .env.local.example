# NextAuth Configuration
# Required: Application URL for NextAuth
NEXTAUTH_URL=http://localhost:3000

# Required: Secret for JWT encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Microsoft Azure AD Provider
# Required: Get these from Azure Portal > App Registrations
AZURE_AD_CLIENT_ID=your-azure-client-id-here
AZURE_AD_CLIENT_SECRET=your-azure-client-secret-here
AZURE_AD_TENANT_ID=your-azure-tenant-id-here

# Supabase Configuration
# Required: Get these from Supabase Project Settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Setup Instructions:
# 1. Copy this file to .env.local
# 2. Replace all placeholder values with your actual credentials
# 3. Generate NEXTAUTH_SECRET: openssl rand -base64 32
# 4. Configure Azure AD redirect URI: http://localhost:3000/api/auth/callback/azure-ad
# 5. Never commit .env.local to version control
